# HRCI Environment Variables
# Copy this file to .env and fill in your values

# --- API Keys (pick at least one) ---
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here

# --- Zhipu AI (optional) ---
# ZHIPU_API_KEY=your_zhipu_key_here

# --- DeepSeek (optional) ---
# DEEPSEEK_API_KEY=your_deepseek_key_here

# --- vLLM (optional) ---
# VLLM_API_KEY=dummy

# --- Pi auth directory (optional, if using local Pi auth instead of API keys) ---
# PI_CODING_AGENT_DIR=./pi-mono/.pi/agent

# --- Custom log/analysis paths (optional) ---
# HRCI_ANALYSIS_BASE=/absolute/path/to/log-repo
